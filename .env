# ============================================
# SUPABASE CONFIGURATION
# ============================================
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# AI / TEXT GENERATION
# Google Gemini API (Free tier available)
# Get key at: https://aistudio.google.com/app/apikey
# ============================================
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
EXPO_PUBLIC_GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent

# ============================================
# IMAGE GENERATION
# Pollinations.ai (Free, no key needed — public API)
# ============================================
EXPO_PUBLIC_IMAGE_API_URL=https://image.pollinations.ai/prompt/

# ============================================
# AUDIO GENERATION
# VoiceRSS (Free tier: 350 requests/day)
# Get key at: https://www.voicerss.org/registration.aspx
# ============================================
EXPO_PUBLIC_VOICERSS_API_KEY=your_voicerss_api_key_here
EXPO_PUBLIC_VOICERSS_API_URL=https://api.voicerss.org/

# ============================================
# VIDEO / SLIDES GENERATION
# Uses Gemini to generate scripts/outlines
# (Video rendering uses free canvas-based approach)
# ============================================

# ============================================
# NEWS / EXTRA CONTENT
# NewsAPI (Free tier: 100 requests/day)
# Get key at: https://newsapi.org/register
# ============================================
EXPO_PUBLIC_NEWS_API_KEY=your_newsapi_key_here
EXPO_PUBLIC_NEWS_API_URL=https://newsapi.org/v2/top-headlines

# ============================================
# UNSPLASH (Free image search)
# Get key at: https://unsplash.com/developers
# ============================================
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
EXPO_PUBLIC_UNSPLASH_API_URL=https://api.unsplash.com
